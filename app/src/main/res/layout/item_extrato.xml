<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_lancamento"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView android:id="@+id/tvSeta" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="10dp" android:text="↓" android:textColor="#EA4335" android:textSize="20sp" android:textStyle="bold" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvDescricao" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="R$ 35,00" android:textColor="#1F1F1F" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/tvCategoria" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Mercado • Feira" android:textColor="#5F6368" android:textSize="14sp" />
    </LinearLayout>

    <ImageView android:id="@+id/btnEditar" android:layout_width="24dp" android:layout_height="24dp" android:layout_marginEnd="12dp" android:src="@android:drawable/ic_menu_edit" />
    <ImageView android:id="@+id/btnExcluir" android:layout_width="22dp" android:layout_height="22dp" android:src="@android:drawable/ic_menu_delete" />
</LinearLayout>
