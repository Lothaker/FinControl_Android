<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E5E7EB">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#2F3650"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnVoltar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/voltar_icon"
            android:scaleType="fitCenter"
            android:contentDescription="Voltar"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvTituloHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:gravity="center"
            android:text="Extrato"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Sair"
            android:src="@drawable/logout"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- CONTEÚDO -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/menu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardTituloExtrato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            app:cardBackgroundColor="#D9D9D9"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvTituloExtrato"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="18dp"
                android:paddingTop="12dp"
                android:paddingEnd="18dp"
                android:paddingBottom="12dp"
                android:fontFamily="sans-serif"
                android:text="Últimas despesas"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvExtrato"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="24dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:itemCount="4"
            tools:listitem="@layout/item_extrato" />

        <TextView
            android:id="@+id/tvSemLancamentos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif"
            android:text="Nenhum lançamento encontrado"
            android:textColor="#6D6D6D"
            android:textSize="16sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- MENU INFERIOR -->
    <LinearLayout
        android:id="@+id/menu"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:background="#2F3650"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnCarteira"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="40dp"
            android:src="@drawable/carteira_icon"
            android:contentDescription="Carteira"/>

        <ImageView
            android:id="@+id/btnGrafico"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="40dp"
            android:src="@drawable/adicionar_icon"
            android:contentDescription="Gráfico"/>

        <ImageView
            android:id="@+id/btnExtrato"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="40dp"
            android:src="@drawable/extrato_icon"
            android:contentDescription="Extrato"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>